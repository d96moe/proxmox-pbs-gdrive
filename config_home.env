# =============================================================================
# config_home.env — Home Proxmox instance (Minisforum, Ryzen AI HX 370)
#
# Usage: cp config_home.env config.env
#
# Storage: LVM thin-pool on NVMe (standard Proxmox install)
# VMs: Windows11, HAOS, Ollama, macOS + LXCs
# =============================================================================


# -----------------------------------------------------------------------------
# PBS DATASTORE
# -----------------------------------------------------------------------------

STORAGE_TYPE="lvm-thin"

PBS_DATASTORE_NAME="local-store"
PBS_DATASTORE_PATH="/mnt/pbs"
PBS_DATASTORE_SIZE="350G"

PBS_LVM_VG="pve"
PBS_LVM_THIN_POOL="data"
PBS_LVM_VOL_NAME="pbs-datastore"


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

PBS_USER="backup@pbs"
PBS_USER_PASSWORD="changeme"   # MUST CHANGE
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

PVE_PBS_STORAGE_ID="pbs-local"
PVE_PBS_SERVER="127.0.0.1"


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

RESTICPROFILE_GDRIVE_REMOTE="gdrive"
RESTICPROFILE_GDRIVE_PATH="bu/proxmox_home"
RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

GDRIVE_CONFIG_FOLDER="proxmox_home_config"
CONFIG_KEEP_DAYS=7
CONFIG_BACKUP_SCHEDULE="04:00"


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
# -----------------------------------------------------------------------------

RESTIC_BACKUP_SCHEDULE="02:30"
RESTIC_FORGET_SCHEDULE="03:30"

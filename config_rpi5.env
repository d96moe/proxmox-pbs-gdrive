# =============================================================================
# config_rpi5.env — Raspberry Pi 5 Proxmox setup (aarch64)
#
# Usage: cp config_rpi5.env config.env
#
# Storage: Dedicated partition on NVMe or USB disk
# VMs: Any
# =============================================================================


# -----------------------------------------------------------------------------
# PVE INSTALLATION (arm64 / Raspberry Pi 5 only)
#
# Used by restore-1-install.sh on first run when PVE is not yet installed.
# Ignored on x86_64 (PVE is installed from the official ISO).
#
# PVE_IFACE: your ethernet interface name. Run 'ip link' to find it.
#   Common values on Pi5: eth0, enp2s0
# PVE_IP: static IP with prefix length, e.g. 192.168.1.200/24
# -----------------------------------------------------------------------------

PVE_HOSTNAME="proxmox"
PVE_IP="192.168.1.200/24"
PVE_GATEWAY="192.168.1.1"
PVE_DNS="8.8.8.8"
PVE_IFACE="eth0"
ROOT_PASSWORD=""           # MUST SET — needed for headless SSH/console access in DR


# -----------------------------------------------------------------------------
# PBS DATASTORE
#
# PBS_PARTITION: the dedicated partition for PBS (must be its own partition,
#   not shared with OS or VMs). Used by sanity check in restore-1-install.sh.
#   Format: /dev/sdXN or /dev/nvme0n1pN
#
# PBS_DATASTORE_PATH: where the partition is mounted.
# -----------------------------------------------------------------------------

PBS_PARTITION="/dev/sda3"
PBS_DATASTORE_NAME="local-store"
PBS_DATASTORE_PATH="/mnt/pbs"


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

PBS_USER="backup@pbs"
PBS_USER_PASSWORD="changeme"   # MUST CHANGE
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

PVE_PBS_STORAGE_ID="pbs-local"
PVE_PBS_SERVER="127.0.0.1"


# -----------------------------------------------------------------------------
# RETENTION
#
# LOCAL: short retention, Google Drive handles long-term
# REMOTE (restic/Google Drive): long-term retention
# -----------------------------------------------------------------------------

PBS_RETENTION_LOCAL="keep-last=3,keep-daily=3"
RESTIC_RETENTION_KEEP_LAST=1
RESTIC_RETENTION_KEEP_DAILY=3
RESTIC_RETENTION_KEEP_WEEKLY=2
RESTIC_RETENTION_KEEP_MONTHLY=3


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

RESTICPROFILE_GDRIVE_REMOTE="gdrive"
RESTICPROFILE_GDRIVE_PATH="bu/proxmox_backup"
RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

GDRIVE_CONFIG_FOLDER="proxmox_backup_config"
CONFIG_KEEP_DAYS=7
CONFIG_BACKUP_SCHEDULE="04:00"


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
# -----------------------------------------------------------------------------

RESTIC_BACKUP_SCHEDULE="02:30"
RESTIC_FORGET_SCHEDULE="03:30"

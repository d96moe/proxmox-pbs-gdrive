# =============================================================================
# config.env — Configuration for proxmox-backup-restore scripts
#
# !! READ BEFORE RUNNING ANY SCRIPT !!
#
# This file is sourced by all three restore scripts.
# Review ALL variables below and adjust for your specific environment
# before running restore-1-install.sh.
#
# Variables marked [MUST CHANGE] are unique to your setup.
# Variables marked [DEFAULT OK] usually work as-is.
# Variables marked [HOME] are pre-set for the home Proxmox instance.
# Variables marked [CABIN] show what to change for the cabin Pi5 instance.
# =============================================================================


# -----------------------------------------------------------------------------
# PBS DATASTORE
# -----------------------------------------------------------------------------

# Name of the PBS datastore (used in PBS config and PVE storage)
# [DEFAULT OK] Same on both home and cabin
PBS_DATASTORE_NAME="local-store"

# Mount point for PBS datastore
# [DEFAULT OK]
PBS_DATASTORE_PATH="/mnt/pbs"

# Size of LVM thin volume to create for PBS datastore
# [HOME]  350G  (home has Windows+HAOS+Ollama+LXCs ~240GB real data)
# [CABIN] 100G  (cabin has only HAOS+UniFi, much smaller)
PBS_DATASTORE_SIZE="350G"

# LVM volume group name — verify with: vgs
# [DEFAULT OK] Usually 'pve' on both home and cabin
PBS_LVM_VG="pve"

# LVM thin pool name — verify with: lvs
# [DEFAULT OK] Usually 'data' on both home and cabin
PBS_LVM_THIN_POOL="data"

# LVM logical volume name for PBS datastore
# [DEFAULT OK]
PBS_LVM_VOL_NAME="pbs-datastore"


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

# PBS backup user
# [DEFAULT OK]
PBS_USER="backup@pbs"

# PBS backup user password
# [MUST CHANGE] Set a strong unique password — store it safely!
PBS_USER_PASSWORD="changeme"

# PBS API token name
# [DEFAULT OK]
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

# Storage ID shown in Proxmox GUI
# [DEFAULT OK]
PVE_PBS_STORAGE_ID="pbs-local"

# PBS server address (localhost since PBS runs on same host)
# [DEFAULT OK]
PVE_PBS_SERVER="127.0.0.1"


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

# rclone remote name — must match what you configured with 'rclone config'
# [DEFAULT OK]
RESTICPROFILE_GDRIVE_REMOTE="gdrive"

# Path in Google Drive where restic repo is stored
# [HOME]  bu/proxmox_home
# [CABIN] bu/proxmox_cabin
RESTICPROFILE_GDRIVE_PATH="bu/proxmox_home"

# Path to restic repository password file
# [DEFAULT OK]
RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

# Google Drive subfolder name for PVE config backups
# [HOME]  proxmox_home_config
# [CABIN] proxmox_cabin_config
GDRIVE_CONFIG_FOLDER="proxmox_home_config"

# Number of daily config backups to keep on Google Drive
# [DEFAULT OK]
CONFIG_KEEP_DAYS=7

# Time for nightly config backup (should run after restic forget)
# [DEFAULT OK]
CONFIG_BACKUP_SCHEDULE="04:00"


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
# -----------------------------------------------------------------------------

# Time for nightly restic backup (should run AFTER PBS backup job)
# PBS backup runs at 02:00, so 02:30 gives 30 min margin
# [DEFAULT OK]
RESTIC_BACKUP_SCHEDULE="02:30"

# Time for restic forget/prune job
# [DEFAULT OK]
RESTIC_FORGET_SCHEDULE="03:30"

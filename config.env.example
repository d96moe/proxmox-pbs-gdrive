# =============================================================================
# config.env.example — Template for proxmox-pbs-gdrive configuration
#
# Copy to config.env and fill in your values:
#   cp config.env.example config.env
#
# See README § Configuration Reference for full documentation of each variable.
# =============================================================================


# -----------------------------------------------------------------------------
# PBS DATASTORE
# -----------------------------------------------------------------------------

PBS_PARTITION="/dev/nvme0n1p4"          # dedicated partition for PBS
PBS_DATASTORE_NAME="local-store"        # name shown in PBS UI
PBS_DATASTORE_PATH="/mnt/pbs"           # mount point


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

PBS_USER="backup@pbs"
PBS_USER_PASSWORD="changeme"            # or: export PBS_USER_PASSWORD=... before running
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

PVE_PBS_STORAGE_ID="pbs-local"         # storage ID shown in PVE


# -----------------------------------------------------------------------------
# RETENTION
#
# LOCAL: short retention, Google Drive handles long-term
# REMOTE (restic/Google Drive): long-term retention
# -----------------------------------------------------------------------------

PBS_RETENTION_LOCAL="keep-last=3,keep-daily=3"
RESTIC_RETENTION_KEEP_LAST=1
RESTIC_RETENTION_KEEP_DAILY=3
RESTIC_RETENTION_KEEP_WEEKLY=2
RESTIC_RETENTION_KEEP_MONTHLY=3


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

RESTICPROFILE_GDRIVE_REMOTE="gdrive"                    # rclone remote name
RESTICPROFILE_GDRIVE_PATH="bu/proxmox_backup"           # path in Google Drive
RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"
CONFIG_ENCRYPT_PASSWORD_FILE="/etc/resticprofile/config-encrypt-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

GDRIVE_CONFIG_FOLDER="proxmox_backup_config"            # subfolder under bu/


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
#
# Recommended order: PBS backup → PBS prune → PBS GC → restic → config backup
# -----------------------------------------------------------------------------

PBS_BACKUP_SCHEDULE="02:00"
PBS_PRUNE_SCHEDULE="03:00"
PBS_GC_SCHEDULE="03:30"
RESTIC_BACKUP_SCHEDULE="04:00"
RESTIC_FORGET_SCHEDULE="04:30"
CONFIG_BACKUP_SCHEDULE="05:00"

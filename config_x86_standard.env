# =============================================================================
# config_x86_standard.env — Standard x86_64 Proxmox setup
#
# Usage: cp config_x86_standard.env config.env
#
# Storage: Dedicated partition on NVMe (lvm-linear or plain partition)
# VMs: Any
# =============================================================================


# -----------------------------------------------------------------------------
# PBS DATASTORE
#
# PBS_PARTITION: the dedicated partition for PBS (must be its own partition,
#   not shared with OS or VMs). Used by sanity check in restore-1-install.sh.
#   Format: /dev/sdXN or /dev/nvme0n1pN
#
# PBS_DATASTORE_PATH: where the partition is mounted.
# -----------------------------------------------------------------------------

PBS_PARTITION="/dev/nvme0n1p4"
PBS_DATASTORE_NAME="local-store"
PBS_DATASTORE_PATH="/mnt/pbs"


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

PBS_USER="backup@pbs"
PBS_USER_PASSWORD="${PBS_USER_PASSWORD:-changeme}"   # or: export PBS_USER_PASSWORD=... before running
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

PVE_PBS_STORAGE_ID="pbs-local"
PVE_PBS_SERVER="127.0.0.1"


# -----------------------------------------------------------------------------
# RETENTION
#
# LOCAL: short retention, Google Drive handles long-term
# REMOTE (restic/Google Drive): long-term retention
# -----------------------------------------------------------------------------

PBS_RETENTION_LOCAL="keep-last=3,keep-daily=3"
RESTIC_RETENTION_KEEP_LAST=1
RESTIC_RETENTION_KEEP_DAILY=3
RESTIC_RETENTION_KEEP_WEEKLY=2
RESTIC_RETENTION_KEEP_MONTHLY=3


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

RESTICPROFILE_GDRIVE_REMOTE="gdrive"
RESTICPROFILE_GDRIVE_PATH="bu/proxmox_backup"
RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

GDRIVE_CONFIG_FOLDER="proxmox_backup_config"
CONFIG_KEEP_DAYS=7


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
#
# PBS_BACKUP_SCHEDULE: when PVE runs vzdump of all VMs/LXCs to PBS
# PBS_PRUNE_SCHEDULE:  when PBS prunes old snapshots (should run after backup)
# PBS_GC_SCHEDULE:     when PBS GC frees pruned chunks (should run after prune)
# RESTIC_BACKUP_SCHEDULE: when restic snapshots PBS datastore to Google Drive
# RESTIC_FORGET_SCHEDULE: when restic prunes old GDrive snapshots
# CONFIG_BACKUP_SCHEDULE: when daily PVE config tarball is uploaded to GDrive
#
# Recommended order: PBS backup → PBS prune → PBS GC → restic → config backup
# -----------------------------------------------------------------------------

PBS_BACKUP_SCHEDULE="02:00"
PBS_PRUNE_SCHEDULE="03:00"
PBS_GC_SCHEDULE="03:30"
RESTIC_BACKUP_SCHEDULE="04:00"
RESTIC_FORGET_SCHEDULE="04:30"
CONFIG_BACKUP_SCHEDULE="05:00"

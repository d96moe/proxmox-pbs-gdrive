# =============================================================================
# config_ci.env — CI-specific configuration for restore/DR pipeline tests
#
# Used by Jenkinsfile.restore-test and Jenkinsfile.dr-test.
# The pipeline copies this file to config.env before running the restore scripts.
#
# Differences from production config.env:
#   - STORAGE_TYPE="dir"         (no LVM in the CI template VM)
#   - PBS_PARTITION="/dev/sdb"   (second disk added to template 9001)
#   - Separate GDrive path       (bu/ci-restore-test, isolated from production)
#   - Aggressive retention       (keep-last=2 / keep-daily=3 to save quota)
# =============================================================================


# -----------------------------------------------------------------------------
# PBS DATASTORE
# -----------------------------------------------------------------------------

# Plain directory on the dedicated second disk — no LVM in the CI VM
STORAGE_TYPE="dir"

# Second disk attached to template 9001; formatted by the pipeline with mkfs.ext4
PBS_PARTITION="/dev/sdb"

# Mount point for the PBS datastore
PBS_DATASTORE_PATH="/mnt/pbs"

# PBS datastore name (used in PBS config and PVE storage)
PBS_DATASTORE_NAME="ci-store"

# PBS_DATASTORE_SIZE is not used for dir storage type
PBS_DATASTORE_SIZE=""


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

PBS_USER="backup@pbs"
PBS_USER_PASSWORD="ci-pbs-local"
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

PVE_PBS_STORAGE_ID="pbs-ci"
PVE_PBS_SERVER="127.0.0.1"


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

RESTICPROFILE_GDRIVE_REMOTE="gdrive"

# Separate GDrive path — keeps CI test data isolated from production backups
RESTICPROFILE_GDRIVE_PATH="bu/ci-restore-test"

RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

# Separate GDrive subfolder for CI config backups
GDRIVE_CONFIG_FOLDER="ci_restore_test_config"

# Keep only 3 days of config backups in CI (vs 7 in production)
CONFIG_KEEP_DAYS=3

CONFIG_BACKUP_SCHEDULE="04:30"


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
# -----------------------------------------------------------------------------

RESTIC_BACKUP_SCHEDULE="02:30"
RESTIC_FORGET_SCHEDULE="03:30"


# -----------------------------------------------------------------------------
# PBS RETENTION
# -----------------------------------------------------------------------------

# Aggressive retention — CI snapshots are throwaway
PBS_RETENTION_LOCAL="keep-last=2"
PBS_PRUNE_SCHEDULE="03:00"
PBS_GC_SCHEDULE="03:30"


# -----------------------------------------------------------------------------
# RESTIC RETENTION
# -----------------------------------------------------------------------------

RESTIC_RETENTION_KEEP_LAST=2
RESTIC_RETENTION_KEEP_DAILY=3
RESTIC_RETENTION_KEEP_WEEKLY=1
RESTIC_RETENTION_KEEP_MONTHLY=1

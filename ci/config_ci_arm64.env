# =============================================================================
# config_ci_arm64.env — CI config for arm64 (Pi 5) pipeline tests
#
# Identical to config_ci.env except GDrive paths are arm64-specific so
# x86 and arm64 CI data never collide.
# =============================================================================


# -----------------------------------------------------------------------------
# PVE INSTALLATION (arm64 only — used by restore-1-install.sh Step 0)
#
# The CI template is vanilla Debian Trixie. Step 0 of restore-1-install.sh
# installs pxvirt, configures the bridge, and reboots. These vars drive that.
# PVE_IFACE is detected dynamically so it works regardless of NIC naming.
# -----------------------------------------------------------------------------

PVE_HOSTNAME="arm64-ci"
PVE_IP="192.168.0.252/24"
PVE_GATEWAY="192.168.0.1"
PVE_DNS="8.8.8.8"
PVE_IFACE="$(ip route show default 2>/dev/null | awk '/default/ {print $5}' | head -1)"


# -----------------------------------------------------------------------------
# PBS DATASTORE
# -----------------------------------------------------------------------------

STORAGE_TYPE="dir"
# Detect data disk: the one that is NOT the root disk (disk order can vary)
_ROOT_DISK="$(lsblk -ndo PKNAME "$(findmnt -n -o SOURCE /)" 2>/dev/null | head -1)"
PBS_PARTITION="/dev/$(lsblk -nd -o NAME | grep -v "^${_ROOT_DISK}$" | head -1)"
PBS_DATASTORE_PATH="/mnt/pbs"
PBS_DATASTORE_NAME="ci-store"
PBS_DATASTORE_SIZE=""


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

PBS_USER="backup@pbs"
PBS_USER_PASSWORD="ci-pbs-local"
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

PVE_PBS_STORAGE_ID="pbs-ci"


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

RESTICPROFILE_GDRIVE_REMOTE="gdrive"

# Separate paths from x86 CI — arm64 CI data stays isolated
RESTICPROFILE_GDRIVE_PATH="bu/ci-restore-test-arm64"
GDRIVE_CONFIG_FOLDER="ci_restore_test_config_arm64"

RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"
CONFIG_ENCRYPT_PASSWORD_FILE="/etc/resticprofile/config-encrypt-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

CONFIG_BACKUP_SCHEDULE="04:30"


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
# -----------------------------------------------------------------------------

PBS_BACKUP_SCHEDULE="02:00"
RESTIC_BACKUP_SCHEDULE="02:30"
RESTIC_FORGET_SCHEDULE="03:30"


# -----------------------------------------------------------------------------
# PBS RETENTION
# -----------------------------------------------------------------------------

PBS_RETENTION_LOCAL="keep-last=2"
PBS_PRUNE_SCHEDULE="03:00"
PBS_GC_SCHEDULE="03:30"


# -----------------------------------------------------------------------------
# RESTIC RETENTION
# -----------------------------------------------------------------------------

RESTIC_RETENTION_KEEP_LAST=2
RESTIC_RETENTION_KEEP_DAILY=3
RESTIC_RETENTION_KEEP_WEEKLY=1
RESTIC_RETENTION_KEEP_MONTHLY=1

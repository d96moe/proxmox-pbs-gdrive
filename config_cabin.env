# =============================================================================
# config_cabin.env — Cabin Proxmox instance (Raspberry Pi 5, 8GB)
#
# Usage: cp config_cabin.env config.env
#
# Storage: dir (Proxmox installed on top of Debian, no LVM)
# VMs: HAOS, UniFi/Debian
# =============================================================================


# -----------------------------------------------------------------------------
# PBS DATASTORE
# -----------------------------------------------------------------------------

STORAGE_TYPE="dir"

PBS_DATASTORE_NAME="local-store"
PBS_DATASTORE_PATH="/mnt/pbs"

# LVM variables not used when STORAGE_TYPE="dir" but kept for reference
PBS_DATASTORE_SIZE="n/a"
PBS_LVM_VG="n/a"
PBS_LVM_THIN_POOL="n/a"
PBS_LVM_VOL_NAME="n/a"


# -----------------------------------------------------------------------------
# PBS USER & AUTH
# -----------------------------------------------------------------------------

PBS_USER="backup@pbs"
PBS_USER_PASSWORD="changeme"   # MUST CHANGE
PBS_TOKEN_NAME="pve-token"


# -----------------------------------------------------------------------------
# PVE STORAGE INTEGRATION
# -----------------------------------------------------------------------------

PVE_PBS_STORAGE_ID="pbs-local"
PVE_PBS_SERVER="127.0.0.1"


# -----------------------------------------------------------------------------
# RESTIC / RCLONE / GOOGLE DRIVE
# -----------------------------------------------------------------------------

RESTICPROFILE_GDRIVE_REMOTE="gdrive"
RESTICPROFILE_GDRIVE_PATH="bu/proxmox_cabin"
RESTIC_PASSWORD_FILE="/etc/resticprofile/restic-password"


# -----------------------------------------------------------------------------
# PVE CONFIG BACKUP
# -----------------------------------------------------------------------------

GDRIVE_CONFIG_FOLDER="proxmox_cabin_config"
CONFIG_KEEP_DAYS=7
CONFIG_BACKUP_SCHEDULE="04:00"


# -----------------------------------------------------------------------------
# BACKUP SCHEDULE
# -----------------------------------------------------------------------------

RESTIC_BACKUP_SCHEDULE="02:30"
RESTIC_FORGET_SCHEDULE="03:30"
